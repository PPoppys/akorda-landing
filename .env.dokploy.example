# ---------------------------------------------------------------------------
# 1. Dokploy Instance
# ---------------------------------------------------------------------------
DOKPLOY_URL=https://dokploy.midominio.com
DOKPLOY_API_KEY=dokploy_api_key_aqui

# ---------------------------------------------------------------------------
# 2. Project & Application
# ---------------------------------------------------------------------------
PROJECT_NAME=akorda
PROJECT_DESCRIPTION="Web corporativa de Akorda"
ENV_NAME=production
APP_NAME=akorda-web
APP_DESCRIPTION="Sitio web estático Astro"

# ---------------------------------------------------------------------------
# 3. Source (GitHub)
# ---------------------------------------------------------------------------
GITHUB_OWNER=mi-usuario-github
GITHUB_REPO=akorda
GITHUB_BRANCH=main
GITHUB_BUILD_PATH=.
# Obtener el ID real con: curl -s -H "x-api-key: TOKEN" "DOKPLOY_URL/api/github.githubProviders" | jq .
GITHUB_ID=github_id_aqui

# ---------------------------------------------------------------------------
# 4. Domain
# ---------------------------------------------------------------------------
DOMAIN_HOST=www.midominio.com
DOMAIN_PORT=80
DOMAIN_HTTPS=true
