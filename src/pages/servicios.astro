---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Servicios" description="Servicios que ofrece Akorda">
  <section class="section">
    <div class="container">
      <h1>Servicios</h1>
      <div class="grid">
        <div class="card">
          <h3>Servicio 1</h3>
          <p>Descripción detallada del primer servicio que ofrece Akorda.</p>
        </div>
        <div class="card">
          <h3>Servicio 2</h3>
          <p>Descripción detallada del segundo servicio que ofrece Akorda.</p>
        </div>
        <div class="card">
          <h3>Servicio 3</h3>
          <p>Descripción detallada del tercer servicio que ofrece Akorda.</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .section {
    padding: 4rem 0;
  }

  h1 {
    margin-bottom: 2.5rem;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  .card {
    padding: 2rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
  }

  .card h3 {
    margin-bottom: 0.75rem;
  }

  .card p {
    color: var(--color-text-muted);
  }
</style>
