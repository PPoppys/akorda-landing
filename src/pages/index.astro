---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Inicio" description="Akorda — Página en construcción">
  <section class="hero">
    <div class="container">
      <h1>Akorda</h1>
      <p class="hero-sub">Página en construcción.</p>
      <p class="hero-note">Oscar y Albert vamos a intentar hacer cosas muuuuy guaaapas!</p>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    padding: 6rem 0 4rem;
    text-align: center;
    background: var(--color-bg-alt);
  }

  .hero h1 {
    font-size: 3.5rem;
    color: var(--color-primary);
    margin-bottom: 1rem;
  }

  .hero-sub {
    font-size: 1.25rem;
    color: var(--color-text-muted);
    margin-bottom: 0.75rem;
  }

  .hero-note {
    max-width: 640px;
    margin: 0 auto;
    color: var(--color-text-muted);
    font-size: 1.05rem;
  }
</style>
