---
const currentPath = Astro.url.pathname;

const links = [
  { href: '/', label: 'Inicio', disabled: false },
  { href: '/servicios', label: 'Servicios', disabled: true },
  { href: '/nosotros', label: 'Nosotros', disabled: true },
  { href: '/contacto', label: 'Contacto', disabled: true },
];
---

<header class="nav">
  <div class="container nav-inner">
    <a href="/" class="logo">Akorda</a>
    <nav>
      {links.map((link) => (
        link.disabled ? (
          <span class="nav-link disabled" aria-disabled="true">{link.label}</span>
        ) : (
          <a
            href={link.href}
            class:list={['nav-link', { active: currentPath === link.href }]}
          >
            {link.label}
          </a>
        )
      ))}
    </nav>
  </div>
</header>

<style>
  .nav {
    border-bottom: 1px solid var(--color-border);
    background: var(--color-bg);
    position: sticky;
    top: 0;
    z-index: 10;
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
  }

  .logo {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-primary);
  }

  .logo:hover {
    text-decoration: none;
  }

  nav {
    display: flex;
    gap: 2rem;
  }

  .nav-link {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    font-weight: 500;
    transition: color 0.15s;
  }

  .nav-link.disabled {
    cursor: default;
    opacity: 0.45;
  }

  .nav-link:hover,
  .nav-link.active {
    color: var(--color-primary);
    text-decoration: none;
  }

  .nav-link.disabled:hover {
    color: var(--color-text-muted);
  }

  @media (max-width: 600px) {
    nav { gap: 1rem; }
    .nav-link { font-size: 0.8rem; }
  }
</style>
